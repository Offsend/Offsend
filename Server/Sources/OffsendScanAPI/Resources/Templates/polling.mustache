<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Scanning…</title>
  <style>
    body { font-family: ui-sans-serif, system-ui, sans-serif; background: #0b0d10; color: #e8eaed; margin: 0; }
    main { max-width: 720px; margin: 48px auto; padding: 0 20px; }
    .muted { color: #9aa4b2; }
    a { color: #5b8cff; }
  </style>
</head>
<body>
  <main>
    <h1>Scan in progress</h1>
    <p id="status" class="muted">Queued…</p>
    <p class="muted">Job <code>{{jobID}}</code></p>
  </main>
  <script>
    const jobID = '{{jobID}}';
    const statusEl = document.getElementById('status');
    async function poll() {
      const response = await fetch('/scan/' + jobID);
      if (!response.ok) {
        statusEl.textContent = 'Job not found.';
        return;
      }
      const payload = await response.json();
      statusEl.textContent = 'Status: ' + payload.status;
      if (payload.status === 'completed') {
        window.location.href = '/r/' + jobID;
        return;
      }
      if (payload.status === 'failed') {
        statusEl.textContent = 'Scan failed: ' + (payload.errorMessage || 'unknown error');
        return;
      }
      setTimeout(poll, 2000);
    }
    poll();
  </script>
</body>
</html>
