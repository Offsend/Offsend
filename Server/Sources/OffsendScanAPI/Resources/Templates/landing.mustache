<!doctype html>
<html lang="en">
<head>
  {{>partial-head}}
  <title>{{ogTitle}}</title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebApplication",
        "name": "Offsend Repository Scan",
        "description": "{{metaDescription}}",
        "url": "{{canonicalURL}}",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "provider": {
          "@type": "Organization",
          "name": "Offsend",
          "url": "https://offsend.io/"
        }
      },
      {
        "@type": "Organization",
        "name": "Offsend",
        "url": "https://offsend.io/",
        "sameAs": [
          "https://github.com/Offsend/Offsend",
          "https://check.offsend.io/",
          "https://radar.offsend.io/"
        ]
      }
    ]
  }
  </script>
</head>
<body class="page-landing">
  {{>partial-nav}}

  <main>
    <section class="hero hero--scan">
      <div class="container">
        <h1 class="headline">See what AI can read<br/>while you build.</h1>
        <p class="lede">Scan a GitHub repository for exposed secrets, configs,<br/>and missing AI ignore rules.</p>

        <form id="scan-form" class="scan-form">
          <div class="scan-form-combo">
            <input id="url" name="url" type="url" placeholder="https://github.com/org/repo" required aria-label="Repository URL">
            <button type="submit" class="btn btn-primary" disabled>Check</button>
          </div>
        </form>

        <ul class="hero-trust" aria-label="Scan guarantees">
          <li class="hero-trust-item">
            <span class="hero-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </span>
            Free scan
          </li>
          <li class="hero-trust-item">
            <span class="hero-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="17" y1="8" x2="22" y2="13"/>
                <line x1="22" y1="8" x2="17" y2="13"/>
              </svg>
            </span>
            No signup
          </li>
          <li class="hero-trust-item">
            <span class="hero-trust-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </span>
            Full file paths stay hidden
          </li>
        </ul>

        <p id="status" class="status-text"></p>

      </div>
    </section>
  </main>

  {{>partial-footer-minimal}}
  {{>partial-scripts}}
  <script src="/assets/landing.js" defer></script>
</body>
</html>
